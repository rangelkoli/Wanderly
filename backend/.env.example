# To separate your traces from other application
LANGSMITH_PROJECT=new-agent

# Choose model provider for graph initialization.
# Supported values: auto, chatgpt, inception, openrouter, ollama
TRAVEL_AGENT_MODEL=auto

# Add API keys for connecting to LLM providers, data sources, and other integrations here
GOOGLE_MAPS_API_KEY=
INCEPTION_API_KEY=
OPENROUTER_API_KEY=
TAVILY_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1
